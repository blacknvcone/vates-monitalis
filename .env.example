# Monetalis Frontend - Environment Variables
# Copy to .env and adjust as needed

# Payload CMS backend URL
# Local: http://localhost:3001 (requires running revamp-portfolio CMS locally)
# Remote: https://cms.danipras.dev (shared CMS instance)
VITE_CMS_URL=https://cms.danipras.dev

# Logto SSO Configuration
# Get these from Logto admin console → Applications → your Monetalis app
VITE_LOGTO_ENDPOINT=https://auth.danipras.dev
VITE_LOGTO_APP_ID=your-app-id-here
VITE_LOGTO_REDIRECT_URI=https://monetalis.danipras.dev/callback
VITE_LOGTO_POST_LOGOUT_URI=https://monetalis.danipras.dev
